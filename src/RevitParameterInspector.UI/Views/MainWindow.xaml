<Window x:Class="RevitParameterInspector.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Blue underlined "research by ID" link; double-click re-inspects that element. -->
        <Style x:Key="ElementIdLinkStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF0066CC" />
            <Setter Property="TextDecorations" Value="Underline" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Double-click to inspect this element" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="8">
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="Reselect" Padding="10,4" Click="OnReselectClick" />
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="Gray"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="330" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Export JSON" Padding="10,4" Margin="0,0,8,0" Click="OnExportJsonClick" />
                <Button Content="Export Markdown" Padding="10,4" Margin="0,0,8,0" Click="OnExportMarkdownClick" />
                <Button Content="Export Excel" Padding="10,4" Margin="0,0,8,0" Click="OnExportExcelClick" />
                <Button Content="Copy AI Context" Padding="10,4" Margin="0,0,8,0" Click="OnCopyAiContextClick" />
                <Button Content="Copy JSON" Padding="10,4" Click="OnCopyJsonClick" />
            </StackPanel>
        </DockPanel>

        <TabControl>

        <TabItem Header="Summary">
            <DataGrid ItemsSource="{Binding SummaryRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Export" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <TabItem Header="Parameters">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox Text="{Binding ParameterSearchText, UpdateSourceTrigger=PropertyChanged}" Width="260" Margin="0,0,16,0" />
                    <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox ItemsSource="{Binding ParameterScopeOptions}" SelectedItem="{Binding SelectedParameterScope}" Width="100" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding FilteredParameters}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Export" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Record.Name}" Width="160" />
                        <DataGridTextColumn Header="Localized Name" Binding="{Binding Record.LocalizedName}" Width="120" />
                        <DataGridTextColumn Header="Scope" Binding="{Binding Record.Scope}" Width="70" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Record.ValueDisplay}" Width="140" />
                        <DataGridTextColumn Header="Raw Value" Binding="{Binding Record.ValueRaw}" Width="100" />
                        <DataGridTextColumn Header="Storage Type" Binding="{Binding Record.StorageType}" Width="90" />
                        <DataGridTextColumn Header="Built-in Parameter" Binding="{Binding Record.BuiltInParameter}" Width="160" />
                        <DataGridTextColumn Header="Kind" Binding="{Binding Record.ParameterKind}" Width="100" />
                        <DataGridTextColumn Header="Read Only" Binding="{Binding Record.IsReadOnly}" Width="70" />
                        <DataGridTextColumn Header="Has Value" Binding="{Binding Record.HasValue}" Width="70" />
                        <DataGridTextColumn Header="API Path" Binding="{Binding Record.ApiPath}" Width="160" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Record.Description}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <TabItem Header="Geometry">
            <DataGrid ItemsSource="{Binding GeometryRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Export" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <TabItem Header="Location">
            <DataGrid ItemsSource="{Binding LocationRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Export" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <TabItem Header="Relationships">
            <DataGrid ItemsSource="{Binding RelationshipRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Export" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220" />
                    <DataGridTemplateColumn Header="Value" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Value}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIdField}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding IdTokens}" VerticalAlignment="Center">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIdField}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Style="{StaticResource ElementIdLinkStyle}"
                                                           Margin="0,0,10,0"
                                                           MouseLeftButtonDown="OnElementIdLinkMouseDown" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <TabItem Header="View / Sheet Context">
            <DockPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Text="No View / Sheet context found."
                           Margin="0,6,0,0"
                           Foreground="Gray">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewSheetContextRows.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <DataGrid ItemsSource="{Binding ViewSheetContextRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Export" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Context Type" Binding="{Binding ContextType}" Width="120" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="280" />
                        <DataGridTemplateColumn Header="ElementId" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding ElementId}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsElementIdLink}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ElementId}"
                                                   VerticalAlignment="Center"
                                                   MouseLeftButtonDown="OnElementIdLinkMouseDown">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ElementIdLinkStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsElementIdLink}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Additional Info" Binding="{Binding AdditionalInfo}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <TabItem Header="Dictionary">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding DictionaryCountsText}" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                    <DockPanel Margin="0,0,0,2" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="Unresolved Terms:" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right"
                                Content="Copy Unresolved Terms"
                                Padding="8,2"
                                Click="OnCopyUnresolvedTermsClick" />
                    </DockPanel>
                    <TextBox Text="{Binding UnresolvedDictionaryTermsText, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Height="90"
                             FontFamily="Consolas"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding DictionaryTerms}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="API Name" Binding="{Binding ApiName}" Width="160" />
                        <DataGridTextColumn Header="Localized Name" Binding="{Binding LocalizedName}" Width="120" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                        <DataGridTextColumn Header="Locale" Binding="{Binding Locale}" Width="70" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <TabItem Header="AI Context">
            <TextBox Text="{Binding AiContext, Mode=OneWay}"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </TabItem>

        <TabItem Header="About Me">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24" MaxWidth="620" HorizontalAlignment="Left">
                    <TextBlock Text="RevitParameterInspector" FontSize="22" FontWeight="Bold" />

                    <TextBlock Text="Created by" Margin="0,18,0,0" Foreground="Gray" />
                    <TextBlock Text="Layton Luo" FontSize="16" FontWeight="SemiBold" />

                    <TextBlock Margin="0,14,0,0"
                               TextWrapping="Wrap"
                               Text="Open-source Revit element context inspector for developers, AI-assisted workflows, and BIM automation." />

                    <TextBlock Text="GitHub" Margin="0,18,0,0" FontWeight="SemiBold" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/laytonluo"
                                   RequestNavigate="OnHyperlinkNavigate">https://github.com/laytonluo</Hyperlink>
                    </TextBlock>

                    <TextBlock Text="LinkedIn" Margin="0,10,0,0" FontWeight="SemiBold" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.linkedin.com/in/layton-luo-55228a253"
                                   RequestNavigate="OnHyperlinkNavigate">https://www.linkedin.com/in/layton-luo-55228a253</Hyperlink>
                    </TextBlock>

                    <TextBlock Text="Facebook Fans Page" Margin="0,10,0,0" FontWeight="SemiBold" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.facebook.com/profile.php?id=61560198794512&amp;locale=zh_TW"
                                   RequestNavigate="OnHyperlinkNavigate">https://www.facebook.com/profile.php?id=61560198794512&amp;locale=zh_TW</Hyperlink>
                    </TextBlock>

                    <TextBlock Text="YouTube" Margin="0,10,0,0" FontWeight="SemiBold" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.youtube.com/@BIMANIA-vs8jp"
                                   RequestNavigate="OnHyperlinkNavigate">https://www.youtube.com/@BIMANIA-vs8jp</Hyperlink>
                    </TextBlock>

                    <TextBlock Text="Community Resources" Margin="0,26,0,0" FontSize="16" FontWeight="Bold" />

                    <TextBlock Text="Taiwan BIM MCP Community（台灣 BIM MCP 社群）" Margin="0,14,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock TextWrapping="Wrap" Text="Taiwan's leading BIM + MCP knowledge-sharing community." />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://shuotao.github.io/REVIT_MCP_study/docs/BIM_MCP/index.html"
                                   RequestNavigate="OnHyperlinkNavigate">https://shuotao.github.io/REVIT_MCP_study/docs/BIM_MCP/index.html</Hyperlink>
                    </TextBlock>

                    <TextBlock Text="Taiwan AEC Open Knowledge Base（台灣 AEC 開源知識庫）" Margin="0,14,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock TextWrapping="Wrap" Text="Open-source knowledge base for Architecture, Engineering, and Construction professionals in Taiwan." />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://h30190.github.io/HJPLUS_Taiwan_Architect_KB/"
                                   RequestNavigate="OnHyperlinkNavigate">https://h30190.github.io/HJPLUS_Taiwan_Architect_KB/</Hyperlink>
                    </TextBlock>

                    <TextBlock Margin="0,22,0,0"
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               Text="Thank you for supporting RevitParameterInspector. Community contributions, bug reports, dictionary improvements, and feature suggestions are welcome." />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        </TabControl>
    </DockPanel>
</Window>
